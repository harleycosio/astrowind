---
import { I18N, METADATA, SITE } from 'astrowind:config';
import type { Props as AstroSeoProps } from '@astrolib/seo';
// biome-ignore lint/correctness/noUnusedImports: <False Positive>
import { AstroSeo } from '@astrolib/seo';
import merge from 'lodash.merge';
import type { MetaData } from '~/types';
// biome-ignore lint/correctness/noUnusedImports: <False Positive>
import { adaptOpenGraphImages } from '~/utils/images';
import { getCanonical } from '~/utils/permalinks';

export interface Props extends MetaData {
  dontUseTitleTemplate?: boolean;
}

const {
  title,
  ignoreTitleTemplate = false,
  canonical = String(getCanonical(String(Astro.url.pathname))),
  robots = {},
  description,
  openGraph = {},
  twitter = {},
  languageAlternates = [],
} = Astro.props;

const seoProps: AstroSeoProps = merge(
  {
    title: '',
    titleTemplate: '%s',
    canonical: canonical,
    noindex: true,
    nofollow: true,
    description: undefined,
    openGraph: {
      url: canonical,
      site_name: SITE?.name,
      images: [],
      locale: I18N?.language || 'en',
      type: 'website',
    },
    twitter: {
      cardType: openGraph?.images?.length ? 'summary_large_image' : 'summary',
    },
  },
  {
    title: METADATA?.title?.default,
    titleTemplate: METADATA?.title?.template,
    noindex: typeof METADATA?.robots?.index !== 'undefined' ? !METADATA.robots.index : undefined,
    nofollow: typeof METADATA?.robots?.follow !== 'undefined' ? !METADATA.robots.follow : undefined,
    description: METADATA?.description,
    openGraph: METADATA?.openGraph,
    twitter: METADATA?.twitter,
  },
  {
    title: title,
    titleTemplate: ignoreTitleTemplate ? '%s' : undefined,
    canonical: canonical,
    noindex: typeof robots?.index !== 'undefined' ? !robots.index : undefined,
    nofollow: typeof robots?.follow !== 'undefined' ? !robots.follow : undefined,
    description: description,
    openGraph: { url: canonical, ...openGraph },
    twitter: twitter,
  }
);

// Hreflang logic
const currentPathname = Astro.url.pathname;
const cleanPath = currentPathname.replace(/^\/es(\/|$)/, '/');
const locales = ['en', 'es'];

// If languageAlternates are provided (e.g. from blog posts with different slugs), use them.
// Otherwise, use the default path-based logic.
const finalLanguageAlternates = languageAlternates.length > 0
  ? languageAlternates
  : locales.map((lang) => ({
      hrefLang: lang,
      href: String(getCanonical(lang === 'en' ? cleanPath : `/es${cleanPath === '/' ? '' : cleanPath}`)),
    }));

const xDefault = finalLanguageAlternates.find((h) => h.hrefLang === 'en' || h.hrefLang === 'x-default')?.href 
                || finalLanguageAlternates[0]?.href;
---

<AstroSeo 
  {...{ ...seoProps, openGraph: await adaptOpenGraphImages(seoProps?.openGraph, Astro.site) }} 
/>

{finalLanguageAlternates.map((h) => (
  <link rel="alternate" hreflang={h.hrefLang} href={h.href} />
))}
{xDefault && <link rel="alternate" hreflang="x-default" href={xDefault} />}
