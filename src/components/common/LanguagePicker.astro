---
import { Icon } from 'astro-icon/components';
import { useLanguageSwitcher } from '~/i18n/utils';

const { currentLang, alternateLang, alternatePath } = useLanguageSwitcher(Astro.url);
---

<div class="flex items-center">
  <a
    href={alternatePath}
    onclick={`localStorage.setItem('preferred-lang', '${alternateLang}')`}
    class="text-muted dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-4 focus:ring-gray-200 dark:focus:ring-gray-700 rounded-lg text-sm p-2.5 inline-flex items-center uppercase font-semibold transition"
    aria-label={`Switch to ${alternateLang === 'en' ? 'English' : 'Español'}`}
  >
    <Icon name="tabler:language" class="w-5 h-5 mr-1" />
    <span>{alternateLang}</span>
  </a>
</div>
