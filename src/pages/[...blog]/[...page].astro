---
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import Headline from "~/components/blog/Headline.astro";
import BlogList from "~/components/blog/List.astro";
import Pagination from "~/components/blog/Pagination.astro";
import Layout from "~/layouts/PageLayout.astro";
// import PostTags from "~/components/blog/Tags.astro";

import { blogListRobots, getStaticPathsBlogList } from "~/utils/blog";

import { useTranslations } from "~/i18n/utils";

export const prerender = true;

export const getStaticPaths = (async ({ paginate }) => {
	return await getStaticPathsBlogList({ paginate });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page, lang } = Astro.props as Props;
const t = useTranslations(lang as 'en' | 'es');
const currentPage = page.currentPage ?? 1;

const metadata = {
	title: `${t('nav.blog')}${currentPage > 1 ? ` — Page ${currentPage}` : ""} | Onsite Car Key`,
	description: lang === 'es' 
    ? "Consejos de cerrajería, guías de seguridad y asesoramiento profesional para dueños de autos en el Sur de Florida."
    : "Expert automotive locksmith tips, vehicle security guides, and professional advice for car owners in South Florida.",
	robots: {
		index: blogListRobots?.index && currentPage === 1,
		follow: blogListRobots?.follow,
	},
	openGraph: {
		title: lang === 'es' ? "Blog de Cerrajería Automotriz - Consejos y Soluciones" : "Auto Locksmith Blog - Expert Tips & Solutions",
		description: lang === 'es' ? "Consejos profesionales y guías de seguridad para conductores en el Sur de Florida." : "Professional automotive locksmith advice and security tips for South Florida drivers.",
		type: "blog",
		url: `https://onsitecarkey.com/${lang === 'en' ? '' : 'es/'}blog${currentPage > 1 ? `/page/${currentPage}` : ""}`,
		image: {
			src: "https://res.cloudinary.com/dx0dcvqlv/image/upload/w_1200,h_626,c_lfill,f_jpg/v1739763607/og_image",
			alt: "Auto Locksmith Tips and Solutions Blog",
			width: 1200,
			height: 630,
		},
		site_name: "Onsite Car Key",
		locale: lang === 'es' ? "es_US" : "en_US",
	},
};
---

<Layout metadata={metadata}>
  <section class="px-6 sm:px-6 py-12 sm:py-16 lg:py-20 mx-auto max-w-4xl">
    <Headline
      subtitle={lang === 'es' 
        ? "Información experta sobre seguridad de vehículos, consejos para el reemplazo de llaves y asesoramiento profesional de cerrajería."
        : "Expert insights on vehicle security, key replacement tips, and professional locksmith advice."}
    >
      {t('nav.blog')}
    </Headline>
    <BlogList posts={page.data} />
    <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
    <!--
      <PostTags tags={allCategories} class="mb-2" title="Search by Categories:" isCategory />
      <PostTags tags={allTags}  title="Search by Tags:" />
    -->
  </section>
</Layout>
